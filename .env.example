# Przyklad pliku .env dla projektu "Niekończące się Lustro"
# Skopiuj ten plik do nazwy: .env i uzupełnij wartości.
# Ten plik NIE zawiera prawdziwych sekretów.

# Klucz API do Gemini (Google Generative AI) – w pliku .env wpisz prawdziwy
GEMINI_API_KEY=WPROWADZ_SWÓJ_KLUCZ_TUTAJ

# Model (opcjonalnie możesz zmienić na inny wariant zgodny z google-generativeai)
GEMINI_MODEL=gemini-1.5-flash
